{
  "version": 8,
  "name": "Starnovo Medieval",
  "sources": {
    "osm": {
      "type": "raster",
      "tiles": [
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#F4E8C1"
      }
    },
    {
      "id": "osm-tiles",
      "type": "raster",
      "source": "osm",
      "paint": {
        "raster-opacity": 0.3,
        "raster-saturation": -1,
        "raster-contrast": 0.2,
        "raster-brightness-min": 0.8
      }
    }
  ]
}